{
  "ConnectionStrings": {
    "Default": ""
  },
  "Keycloak": {
    "Authority": "",
    "ClientId": "cloudsmith-api",
    "ClientSecret": "",
    "RequireHttpsMetadata": false
  },
  "Monitoring": {
    "HealthCheckIntervalSeconds": 30,
    "Endpoints": [
      { "Name": "api",      "ComponentType": "api",      "HealthUrl": "http://localhost:8080/health/ready" },
      { "Name": "portal",   "ComponentType": "portal",   "HealthUrl": "https://ca-cloudsmith-portal-dev-cus-001.wonderfulflower-5de05030.centralus.azurecontainerapps.io" },
      { "Name": "postgres", "ComponentType": "database", "HealthUrl": "http://localhost:8080/health/ready" }
    ]
  },
  "OpenTelemetry": {
    "Endpoint": "http://otel-collector:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
